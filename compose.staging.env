# Staging env. Container-internal ports mirror prod (8000/8080); the host-side
# mapping is overridden in docker-compose.staging.yml.
BACKEND_PORT=8000
SEARXNG_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443

BACKEND_INTERNAL=http://backend:8000
SEARXNG_INTERNAL=http://searxng:8080

DOMAIN=staging-deeppin.duckdns.org
