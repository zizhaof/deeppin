# compose.env — 所有组件的端口和服务地址，单一来源
# 修改端口只需改这里，docker-compose.yml 自动跟着变

# 端口 / Ports
BACKEND_PORT=8000
SEARXNG_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443

# 容器内部服务地址（Docker 网络内互相访问）/ Internal service addresses
BACKEND_INTERNAL=http://backend:8000
SEARXNG_INTERNAL=http://searxng:8080

# 对外域名 / Public domain
DOMAIN=deeppin.duckdns.org
