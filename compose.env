# compose.env — single source of truth for every component's port + service URL.
# Change a port here; docker-compose.yml picks up the new value automatically.

# Ports
BACKEND_PORT=8000
SEARXNG_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443

# Internal service addresses (container-to-container over the Docker network)
BACKEND_INTERNAL=http://backend:8000
SEARXNG_INTERNAL=http://searxng:8080

# Public domain
DOMAIN=deeppin.duckdns.org
